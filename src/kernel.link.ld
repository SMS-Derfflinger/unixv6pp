/* 코뵙뭐쉔졍쌈신굶。 */

ENTRY(greatstart)

SECTIONS
{
    
    .text 0xc0100000:
    {
        *(.sector2)
        *(.text)
        *(.rodata*)
        . = ALIGN(4096);
    }
    
    .data :
    {
        
        *(.data)
        . = ALIGN(4096);

        /* 뭐芚변鑒죗깊。
           꽝옘：https://ftp.gnu.org/old-gnu/Manuals/ld-2.9.1/text/ld.txt */
        __CTOR_LIST__ = .;
        *(.init_array)
        *(.ctors)
        __CTOR_END__ = .;

        . = ALIGN(4096);

        /* 驕뭐변鑒죗깊。 */
        __DTOR_LIST__ = .;
        *(.dtors)
        __DTOR_END__ = .;

        . = ALIGN(4096);
    }


    .bss : 
    {
        __BSS_START__ = .;
     
        *(.bss)
        . = ALIGN(4096);

        __BSS_END__ = .;
    }

}
